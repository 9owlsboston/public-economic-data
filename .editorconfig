root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{ps1,psm1,cmd,bat}]
end_of_line = crlf

[*.{py}]
indent_size = 4

[*.{go}]
indent_style = tab
